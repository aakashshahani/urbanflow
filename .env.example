# ── Local stack (MinIO / Trino / Iceberg REST) ──────────────────────────────
# These defaults match docker-compose.yml; copy to .env and adjust if needed.

# MinIO (S3-compatible local object store)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
WAREHOUSE_BUCKET=urbanflow

# Iceberg REST catalog
ICEBERG_CATALOG_URI=http://localhost:8181

# Trino
TRINO_HOST=localhost
TRINO_PORT=8080
TRINO_USER=urbanflow
TRINO_CATALOG=iceberg

# ── Target selector: "local" (Trino/MinIO) or "aws" (Athena/S3/Glue) ────────
URBANFLOW_TARGET=local

# ── AWS deploy only (filled by terraform outputs; leave blank for local) ────
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY above are reused for real AWS.
ATHENA_WORKGROUP=urbanflow
ATHENA_OUTPUT_S3=
GLUE_DATABASE=urbanflow

# ── Ingestion knobs ─────────────────────────────────────────────────────────
# Sample slice for fast local dev; expand for the volume run.
TLC_DATASET=yellow
TLC_MONTHS=2024-01
WEATHER_LAT=40.7128
WEATHER_LON=-74.0060
